{
  "name": "@gkiely/safe-install",
  "version": "0.1.30",
  "description": "Run npm installs with dependency lifecycle scripts disabled, then rebuild explicitly trusted dependencies.",
  "author": "Grant Kiely <grant@youneedawiki.com>",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "npm",
    "install",
    "security",
    "supply-chain",
    "trusted-dependencies"
  ],
  "engines": {
    "node": ">=14"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gkiely/safe-install.git"
  },
  "bugs": {
    "url": "https://github.com/gkiely/safe-install/issues"
  },
  "homepage": "https://github.com/gkiely/safe-install#readme",
  "publishConfig": {
    "access": "public"
  },
  "blockExoticSubDeps": true,
  "bin": {
    "safe-install": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test",
    "release": "node scripts/release.ts",
    "safe-install": "node dist/index.js",
    "test": "npm run build && node --test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "typescript": "latest"
  },
  "volta": {
    "node": "24.14.1",
    "npm": "11.14.1"
  }
}
